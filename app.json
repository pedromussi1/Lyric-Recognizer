{
  "expo": {
    "name": "Lyric Recognizer",
    "slug": "lyric-recognizer",
    "description": "Sing or speak song lyrics to find the matching song, with one-tap links to Spotify and Apple Music.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a14"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#a855f7"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "Lyric Recognizer",
      "themeColor": "#a855f7",
      "backgroundColor": "#0a0a14"
    }
  }
}
